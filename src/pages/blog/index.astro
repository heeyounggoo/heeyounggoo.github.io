---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog | heeyounggoo" description="구희영의 기술 블로그">
  <div class="mb-10">
    <h1 class="mb-2 text-3xl font-bold text-gray-900">Blog</h1>
    <p class="text-gray-500">개발하면서 배운 것들을 기록합니다.</p>
  </div>

  {
    posts.length === 0 ? (
      <p class="py-20 text-center text-gray-400">아직 포스트가 없습니다.</p>
    ) : (
      <ul class="flex flex-col gap-4">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id.replace(/\.mdx$/, "")}`}
              class="group block rounded-lg border border-gray-100 p-6 transition-all hover:border-orange-200 hover:shadow-sm"
            >
              <div class="flex items-start justify-between gap-6">
                <div class="min-w-0 flex-1">
                  {post.data.categories && post.data.categories.length > 0 && (
                    <div class="mb-2 flex gap-2">
                      {post.data.categories.map((cat) => (
                        <span class="rounded-full border border-orange-100 bg-orange-50 px-2.5 py-0.5 text-xs font-semibold text-orange-600">
                          {cat}
                        </span>
                      ))}
                    </div>
                  )}
                  <h2 class="mb-1 truncate text-lg font-semibold text-gray-900 transition-colors group-hover:text-orange-500">
                    {post.data.title}
                  </h2>
                  <p class="line-clamp-2 text-sm text-gray-500">
                    {post.data.description}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-3 flex gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs text-gray-400">#{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <time
                  class="shrink-0 pt-1 text-xs text-gray-400"
                  datetime={post.data.date.toISOString()}
                >
                  {post.data.date.toLocaleDateString("ko-KR", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
