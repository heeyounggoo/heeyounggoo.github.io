---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
---

<BaseLayout title="이력서 | 구희영" description="구희영 프론트엔드 개발자 경력기술서">
  <style is:global>
    .page {
      width: 794px;
      min-height: 1123px;
      background: #ffffff;
      margin: 24px auto;
      padding: 60px 64px;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
      position: relative;
    }

    .page h2 {
      font-size: 20px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 16px;
      padding-left: 14px;
      border-left: 4px solid #f97316;
      line-height: 1.3;
    }

    .page h3 {
      font-size: 14px;
      font-weight: 700;
      color: #222222;
      margin-bottom: 6px;
    }

    .page p,
    .page li {
      font-size: 13px;
      line-height: 1.7;
      color: #333333;
    }

    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 40px;
      padding-bottom: 32px;
      border-bottom: 1.5px solid #f0f0f0;
    }

    .header-left h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      color: #111111;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }

    .header-left .tagline {
      font-size: 14px;
      color: #555555;
      margin-bottom: 12px;
      font-weight: 400;
    }

    .header-left .role-badge {
      display: inline-flex;
      align-items: center;
      background: #fff7ed;
      color: #ea580c;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid #fdba74;
    }

    .contact-grid {
      display: flex;
      flex-direction: column;
      gap: 6px;
      text-align: right;
    }

    .contact-item {
      font-size: 12px;
      color: #666666;
      display: flex;
      align-items: center;
      gap: 6px;
      justify-content: flex-end;
    }

    .contact-item .label {
      font-weight: 600;
      color: #f97316;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .section {
      margin-bottom: 36px;
    }

    .career-item {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 16px;
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid #f5f5f5;
    }

    .career-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .career-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
      padding-top: 2px;
      white-space: nowrap;
    }

    .career-date .company {
      font-size: 13px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 2px;
    }

    .career-date .duration {
      font-size: 11px;
      color: #f97316;
      font-weight: 600;
    }

    .career-content .position {
      font-size: 13px;
      font-weight: 600;
      color: #333333;
      margin-bottom: 6px;
    }

    .career-content ul {
      list-style: none;
      padding: 0;
    }

    .career-content ul li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12.5px;
      max-width: 65ch;
    }

    .career-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #f97316;
      opacity: 0.7;
    }

    .tech-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .tech-tag {
      font-size: 11.5px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 4px;
      background: #fff7ed;
      color: #ea580c;
      border: 1px solid #fed7aa;
    }

    .tech-tag.secondary {
      background: #f9fafb;
      color: #4b5563;
      border-color: #e5e7eb;
    }

    .project-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      padding-bottom: 12px;
      border-bottom: 2px solid #f97316;
    }

    .project-company {
      font-size: 14px;
      font-weight: 700;
      color: #111111;
    }

    .project-service-sep {
      color: #f97316;
      font-weight: 400;
    }

    .project-service {
      font-size: 13px;
      color: #555555;
      font-weight: 500;
    }

    .project-title {
      font-size: 20px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 4px;
      letter-spacing: -0.3px;
    }

    .project-section {
      margin-bottom: 20px;
    }

    .project-section-label {
      display: block;
      font-size: 15px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 8px;
    }

    .project-title + .tech-tags {
      margin-top: 10px;
      margin-bottom: 20px;
    }

    .project-title + .tech-tags .tech-tag:nth-child(odd) {
      background: #fff7ed;
      color: #ea580c;
      border-color: #fed7aa;
      border-radius: 8px;
    }

    .project-title + .tech-tags .tech-tag:nth-child(even) {
      background: #f9fafb;
      color: #4b5563;
      border-color: #e5e7eb;
      border-radius: 8px;
    }

    .project-content ul {
      list-style: none;
      padding: 0;
    }

    .project-content ul li {
      padding-left: 16px;
      position: relative;
      margin-bottom: 6px;
      font-size: 12.5px;
      max-width: 65ch;
      line-height: 1.7;
    }

    .project-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #f97316;
    }

    .sub-list {
      list-style: none;
      padding: 0;
      margin-top: 2px;
      margin-left: 8px;
    }

    .sub-list > li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12.5px;
      max-width: 60ch;
      line-height: 1.7;
    }

    .sub-list > li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 10px;
      width: 8px;
      height: 1.5px;
      background: #aaaaaa;
    }

    .sub-sub-list {
      list-style: none;
      padding: 0;
      margin-top: 2px;
      margin-left: 8px;
    }

    .sub-sub-list > li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12px;
      color: #555555;
      max-width: 58ch;
      line-height: 1.7;
    }

    .sub-sub-list > li::before {
      content: "";
      position: absolute;
      left: 2px;
      top: 9px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      border: 1px solid #aaaaaa;
      background: transparent;
    }

    .edu-item {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 16px;
      align-items: start;
    }

    .edu-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
    }

    .edu-content h3 {
      margin-bottom: 2px;
    }

    .edu-content p {
      font-size: 12px;
      color: #666666;
    }

    .page-num {
      position: absolute;
      bottom: 28px;
      right: 64px;
      font-size: 11px;
      color: #cccccc;
    }

    @media print {
      body {
        background: white;
      }
      .page {
        margin: 0;
        box-shadow: none;
        page-break-after: always;
      }
    }
  </style>

  <!-- PAGE A-1: 프로필 요약 -->
  <div class="page">
    <div class="header">
      <div class="header-left">
        <h1>구희영</h1>
        <p class="tagline">함께 일하고 싶은 개발자, 구희영입니다.</p>
        <span class="role-badge">Frontend Developer</span>
      </div>
      <div class="contact-grid">
        <div class="contact-item">
          <span class="label">Email</span>
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
        </div>
        <div class="contact-item">
          <span class="label">GitHub</span>
          <a href={profile.github} target="_blank" rel="noopener noreferrer">
            github.com/heeyounggoo
          </a>
        </div>
      </div>
    </div>

    <!-- 기술 스택 -->
    <div class="section">
      <h2>기술스택</h2>
      {
        Object.entries(profile.skills).map(([category, items]) => (
          <div style="margin-bottom: 12px;">
            <h3
              style="font-size:12px; color:#888; font-weight:600; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.5px;"
            >
              {category}
            </h3>
            <div class="tech-tags">
              {items.map((skill) => (
                <span
                  class={
                    category === "Frontend" ? "tech-tag" : "tech-tag secondary"
                  }
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- 경력 -->
    <div class="section">
      <h2>경력사항</h2>
      <div class="career-item">
        <div class="career-date">
          <div class="company">라이드</div>
          <div class="duration">2023.10 – 현재</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">재직 중</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>모빌리티 서비스 프론트엔드 개발</li>
            <li>사내 디자인시스템 구축 및 컴포넌트 라이브러리 개발</li>
          </ul>
        </div>
      </div>

      <div class="career-item">
        <div class="career-date">
          <div class="company">핏투게더</div>
          <div class="duration">2021.08 – 2023.08</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">2년</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>스포츠 선수 리포트 서비스 프론트엔드 개발</li>
          </ul>
        </div>
      </div>

      <div class="career-item">
        <div class="career-date">
          <div class="company">ANTLabs</div>
          <div class="duration">2019.03 – 2021.07</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">2년</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>대학교 학사 시스템 프론트엔드 개발</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 학력 -->
    <div class="section">
      <h2>학력</h2>
      <div class="edu-item" style="margin-bottom: 16px;">
        <div class="edu-date">2018.03 – 2023.08</div>
        <div class="edu-content">
          <h3>한국방송통신대학교</h3>
          <p>컴퓨터과학과</p>
        </div>
      </div>
      <div class="edu-item">
        <div class="edu-date">2014.03 – 2016.02</div>
        <div class="edu-content">
          <h3>인덕대학교</h3>
          <p>미디어아트앤디자인과</p>
        </div>
      </div>
    </div>

<span class="page-num">1 / 6</span>
  </div>

  <!-- PAGE A-2: 라이드 프론트엔드 개발 환경 설계 -->
  <div class="page">
    <div class="project-header">
      <span class="project-company">라이드</span>
      <span class="project-service-sep">·</span>
      <span class="project-service">모빌리티 서비스 개발</span>
    </div>

    <div class="project-title">프론트엔드 개발 환경 설계</div>

    <div class="tech-tags">
      <span class="tech-tag">Turborepo</span>
      <span class="tech-tag">pnpm</span>
      <span class="tech-tag">React 19</span>
      <span class="tech-tag">Next.js</span>
      <span class="tech-tag">zod</span>
      <span class="tech-tag">husky</span>
      <span class="tech-tag">lint-staged</span>
    </div>

    <div class="project-section">
      <span class="project-section-label">배경</span>
      <div class="project-content">
        <ul>
          <li>개별 레포지토리 관리로 인한 중복 기능 발생</li>
          <li>신규 도메인 확장 시 web/admin에서 공통으로 사용되는 부분들이 많아짐에 따라 개발 생산성 고려</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <span class="project-section-label">작업 상세</span>
      <div class="project-content">
        <ul>
          <li><strong>Turborepo</strong>와 <strong>pnpm</strong> 기반의 모노레포 도입 제안하여 프론트엔드 개발 환경 통합</li>
          <li>각 서비스에 맞는 프레임워크 사용
            <ul class="sub-list">
              <li><strong>React 19(Admin)</strong>
                <ul class="sub-sub-list">
                  <li>비즈니스 로직 복잡도가 높아 서버/클라이언트 경계 관리 부담을 줄이고 클라이언트 상태 관리에 집중</li>
                  <li>복잡한 데이터 테이블과 form 처리 성능 개선</li>
                  <li>react-query 기반 클라이언트 캐싱 전략 적용 — Optimistic Update 및 실시간 상태 반영(Query Invalidate)</li>
                </ul>
              </li>
              <li><strong>Next.js(Web)</strong>
                <ul class="sub-sub-list">
                  <li>차량 구매 도메인을 위해 SEO 최적화 필요</li>
                  <li>SSR을 통한 초기 렌더링 속도 개선</li>
                </ul>
              </li>
            </ul>
          </li>
          <li><code>pnpm catalog</code>를 통한 의존성 최적화 및 버전 일관성 유지</li>
          <li>CI/CD 효율화 — Turborepo의 캐싱 및 필터링 기능을 활용하여 변경된 내용만 빌드/배포</li>
          <li>zod를 이용한 API 요청/응답값 type 검증하여 안정성 확보</li>
          <li>husky + lint-staged 활용해 커밋 전 lint/type 오류 사전 검증</li>
          <li>AI 사용 시 필요한 프론트엔드 Rules/Skills 가이드라인 작성</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <span class="project-section-label">인사이트</span>
      <div class="project-content">
        <ul>
          <li>CI/CD 효율화로 배포 리소스 절감</li>
          <li>온보딩 시간 단축 — 신규 개발자가 하나의 레포에서 전체 컨텍스트 파악 가능, 초기 적응 기간 단축</li>
          <li>프론트엔드 팀 개발 생산성 향상, 코드 일관성 확보</li>
        </ul>
      </div>
    </div>

<span class="page-num">2 / 6</span>
  </div>

  <!-- PAGE A-3: 라이드 디자인시스템 -->
  <div class="page">
    <div class="project-header">
      <span class="project-company">라이드</span>
      <span class="project-service-sep">·</span>
      <span class="project-service">디자인시스템</span>
    </div>

    <div class="project-title">디자인시스템 구축</div>

    <div class="tech-tags">
      <span class="tech-tag">React</span>
      <span class="tech-tag">TypeScript</span>
      <span class="tech-tag">Storybook</span>
      <span class="tech-tag">Rollup</span>
      <span class="tech-tag">CSS Modules</span>
      <span class="tech-tag">GitHub Actions</span>
    </div>

    <div class="project-section">
      <span class="project-section-label">배경</span>
      <div class="project-content">
        <ul>
          <li>디자이너–개발자 협업을 위한 사내 디자인시스템 구축</li>
          <li>40+ 재사용 UI 컴포넌트 라이브러리 설계 및 구현</li>
          <li>Storybook 기반 컴포넌트 문서화 및 시각적 회귀 테스트</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <span class="project-section-label">작업 상세</span>
      <div class="project-content">
        <ul>
          <li>Button, Input, Modal, Toast 등 핵심 UI 컴포넌트 설계 및 개발</li>
          <li>디자인 토큰(색상, 타이포그래피, 간격) 체계 수립</li>
          <li>Storybook 문서화로 디자이너·QA 팀 협업 효율 40% 향상</li>
          <li>npm 패키지 배포 파이프라인 구축 (GitHub Actions CI/CD)</li>
          <li>접근성(A11y) 가이드라인 적용 (WCAG 2.1 AA 기준)</li>
        </ul>
      </div>
    </div>

<span class="page-num">3 / 6</span>
  </div>

  <!-- PAGE A-4: 핏투게더 스포츠 선수 리포트 -->
  <div class="page">
    <div class="project-header">
      <span class="project-company">핏투게더</span>
      <span class="project-service-sep">·</span>
      <span class="project-service">스포츠 선수 리포트 서비스</span>
    </div>

    <div class="project-title">스포츠 선수 리포트 서비스 개발</div>

    <div class="tech-tags">
      <span class="tech-tag">React</span>
      <span class="tech-tag">TypeScript</span>
      <span class="tech-tag">Recharts</span>
      <span class="tech-tag">Recoil</span>
      <span class="tech-tag">React Query</span>
      <span class="tech-tag">html2canvas</span>
    </div>

    <div class="project-section">
      <span class="project-section-label">배경</span>
      <div class="project-content">
        <ul>
          <li>선수별 퍼포먼스 지표 데이터 시각화 대시보드 개발</li>
          <li>코치·구단 관계자를 위한 분석 리포트 생성 및 공유 시스템</li>
          <li>복잡한 차트/그래프 UI 컴포넌트 개발</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <span class="project-section-label">작업 상세</span>
      <div class="project-content">
        <ul>
          <li>Recharts 기반 커스텀 차트 컴포넌트 개발 (레이더, 바, 라인 차트)</li>
          <li>PDF 리포트 생성 기능 구현 (html2canvas + jsPDF)</li>
          <li>선수 비교 분석 UI/UX 설계 및 개발</li>
          <li>데이터 필터링 및 기간별 조회 기능 구현</li>
          <li>반응형 대시보드 레이아웃 설계 (태블릿/데스크톱 최적화)</li>
        </ul>
      </div>
    </div>

<span class="page-num">4 / 6</span>
  </div>

  <!-- PAGE A-5: 핏투게더 리포트 & ANTLabs -->
  <div class="page">
    <div class="project-header">
      <span class="project-company">핏투게더</span>
      <span class="project-service-sep">·</span>
