---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { career, education, projects } from "../data/resumeData";
---

<BaseLayout
  title="이력서 | 구희영"
  description="구희영 프론트엔드 개발자 경력기술서"
>
  <style is:global>
    .page {
      width: 100%;
      max-width: 794px;
      min-height: auto;
      background: #ffffff;
      margin: 24px auto;
      padding: 48px 64px;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
      position: relative;
    }

    .page h2 {
      font-size: 20px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 12px;
      padding-left: 14px;
      border-left: 4px solid #f97316;
      line-height: 1.3;
    }

    .page h3 {
      font-size: 14px;
      font-weight: 700;
      color: #222222;
      margin-bottom: 6px;
    }

    .page p,
    .page li {
      font-size: 13px;
      line-height: 1.7;
      color: #333333;
    }

    .header {
      margin-bottom: 28px;
      padding-bottom: 24px;
      border-bottom: 1.5px solid #f0f0f0;
    }

    .header-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .header-left h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      color: #111111;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }

    .header-left .tagline {
      font-size: 14px;
      color: #555555;
      margin-bottom: 12px;
      font-weight: 400;
    }

    .header-bio {
      font-size: 13.5px;
      color: #555555;
      line-height: 1.8;
      white-space: pre-line;
    }

    .header-left .role-badge {
      display: inline-flex;
      align-items: center;
      background: #fff7ed;
      color: #ea580c;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid #fdba74;
    }

    .contact-grid {
      display: flex;
      flex-direction: column;
      gap: 6px;
      text-align: right;
    }

    .contact-item {
      font-size: 12px;
      color: #666666;
      display: flex;
      align-items: center;
      gap: 6px;
      justify-content: flex-end;
    }

    .contact-item .label {
      font-weight: 600;
      color: #f97316;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .section {
      margin-bottom: 36px;
    }

    .career-item {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 16px;
      margin-bottom: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid #f5f5f5;
    }

    .career-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .career-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
      padding-top: 2px;
      white-space: nowrap;
    }

    .career-date .company {
      font-size: 13px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 2px;
    }

    .career-date .duration {
      font-size: 11px;
      color: #f97316;
      font-weight: 600;
    }

    .career-content .position {
      font-size: 13px;
      font-weight: 600;
      color: #333333;
      margin-bottom: 6px;
    }

    .career-content ul {
      list-style: none;
      padding: 0;
    }

    .career-content ul li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12.5px;
    }

    .career-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #f97316;
      opacity: 0.7;
    }

    .tech-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .tech-tag {
      font-size: 11.5px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 4px;
      background: #fff7ed;
      color: #ea580c;
      border: 1px solid #fed7aa;
    }

    .tech-tag.secondary {
      background: #f9fafb;
      color: #4b5563;
      border-color: #e5e7eb;
    }

    .project-header {
      padding-bottom: 14px;
      border-bottom: 2px solid #f97316;
      margin-bottom: 24px;
    }

    .project-header-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .company-summary {
      font-size: 12.5px;
      color: #888888;
      margin: 4px 0 0;
      line-height: 1.6;
    }

    .project-company {
      font-size: 28px;
      font-weight: 800;
      color: #111111;
      letter-spacing: -0.5px;
    }

    .project-service-sep {
      color: #f97316;
      font-weight: 400;
    }

    .project-service {
      font-size: 13px;
      color: #333333;
      font-weight: 600;
    }

    .project-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      padding-top: 12px;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .meta-label {
      font-size: 10.5px;
      font-weight: 600;
      color: #f97316;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .meta-value {
      font-size: 12px;
      color: #444444;
      font-weight: 500;
    }

    .meta-sep {
      color: #dddddd;
      font-size: 14px;
      font-weight: 300;
    }

    .category-item {
      padding-left: 0 !important;
      margin-top: 20px !important;
      margin-bottom: 6px !important;
    }

    .category-item::before {
      display: none !important;
    }

    .category-item > strong {
      display: block;
      border-left: 2px solid #f97316;
      padding-left: 10px;
      margin-bottom: 2px;
    }

    .project-title {
      font-size: 20px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 4px;
      letter-spacing: -0.3px;
    }

    .section-divider {
      margin-top: 28px;
      padding-top: 20px;
      border-top: 1px solid #f0f0f0;
    }

    .project-section {
      margin-bottom: 20px;
    }

    .project-section-label {
      display: block;
      font-size: 15px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 8px;
    }

    .project-title + .tech-tags {
      margin-top: 10px;
      margin-bottom: 20px;
    }

    .project-title + .tech-tags .tech-tag:nth-child(odd) {
      background: #fff7ed;
      color: #ea580c;
      border-color: #fed7aa;
      border-radius: 8px;
    }

    .project-title + .tech-tags .tech-tag:nth-child(even) {
      background: #f9fafb;
      color: #4b5563;
      border-color: #e5e7eb;
      border-radius: 8px;
    }

    .project-content ul {
      list-style: none;
      padding: 0;
    }

    .project-content ul li {
      padding-left: 16px;
      position: relative;
      margin-bottom: 6px;
      font-size: 12.5px;
      line-height: 1.7;
    }

    .project-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #f97316;
    }

    .sub-list {
      list-style: none;
      padding: 0;
      margin-top: 2px;
      margin-left: 8px;
    }

    .sub-list > li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12.5px;
      line-height: 1.7;
    }

    .sub-list > li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 10px;
      width: 8px;
      height: 1.5px;
      background: #aaaaaa;
    }

    .sub-sub-list {
      list-style: none;
      padding: 0;
      margin-top: 2px;
      margin-left: 8px;
    }

    .sub-sub-list > li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12px;
      color: #555555;
      line-height: 1.7;
    }

    .sub-sub-list > li::before {
      content: "";
      position: absolute;
      left: 2px;
      top: 9px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: #aaaaaa;
    }

    .edu-item {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 16px;
      align-items: start;
    }

    .edu-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
    }

    .edu-content h3 {
      margin-bottom: 2px;
    }

    .edu-content p {
      font-size: 12px;
      color: #666666;
    }

    .page-num {
      position: absolute;
      bottom: 28px;
      right: 64px;
      font-size: 11px;
      color: #cccccc;
    }

    @media (max-width: 640px) {
      .page {
        margin: 0;
        padding: 24px 20px;
        box-shadow: none;
        border-bottom: 1px solid #f0f0f0;
      }

      .header-top {
        flex-direction: column;
        gap: 16px;
      }

      .contact-grid {
        text-align: left;
      }

      .contact-item {
        justify-content: flex-start;
      }

      .header-left h1 {
        font-size: 26px;
      }

      .career-item {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .edu-item {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .project-company {
        font-size: 22px;
      }

      .project-meta {
        flex-wrap: wrap;
        gap: 8px;
      }

      .page-num {
        position: static;
        display: block;
        text-align: right;
        margin-top: 24px;
        padding-top: 12px;
        border-top: 1px solid #f5f5f5;
      }
    }

    @media (min-width: 641px) and (max-width: 860px) {
      .page {
        margin: 16px auto;
        padding: 36px 40px;
      }
    }

    @page {
      size: auto;
      margin: 0;
    }

    @media print {
      .page {
        width: 794px;
        min-height: auto;
      }
      html,
      body {
        background: white;
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
      main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: none !important;
      }
      .page {
        margin: 0;
        box-shadow: none;
        page-break-after: auto;
        page-break-inside: avoid;
      }
      .page:last-of-type {
        page-break-after: avoid;
      }
      header,
      footer,
      #pdf-btn {
        display: none !important;
      }
    }
  </style>

  <!-- PAGE A-1: 프로필 요약 -->
  <div class="page">
    <div class="header">
      <div class="header-top">
        <div class="header-left">
          <div style="display:flex; align-items:center; gap:12px;">
            <h1>구희영</h1>
            <span class="role-badge">Frontend Developer</span>
          </div>
        </div>
        <div class="contact-grid">
          <div class="contact-item">
            <span class="label">Email</span>
            <a href={`mailto:${profile.email}`}>{profile.email}</a>
          </div>
          <div class="contact-item">
            <span class="label">GitHub</span>
            <a href={profile.github} target="_blank" rel="noopener noreferrer">
              github.com/heeyounggoo
            </a>
          </div>
        </div>
      </div>
      <p class="header-bio mt-8">{profile.bio.trim()}</p>
    </div>

    <!-- 기술 스택 -->
    <div class="section">
      <h2>기술스택</h2>
      {
        Object.entries(profile.skills).map(([category, items]) => (
          <div style="margin-bottom: 8px;">
            <h3 style="font-size:12px; color:#888; font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">
              {category}
            </h3>
            <div class="tech-tags">
              {items.map((skill) => (
                <span
                  class={
                    category === "Frontend" ? "tech-tag" : "tech-tag secondary"
                  }
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- 경력 -->
    <div class="section">
      <h2>경력사항</h2>
      {
        career.map((item) => (
          <div class="career-item">
            <div class="career-date">
              <div class="company">{item.company}</div>
              {item.companyDesc && (
                <div style="font-size:10.5px; color:#999; margin-bottom:2px; line-height:1.4;">
                  {item.companyDesc}
                </div>
              )}
              <div class="duration">{item.period}</div>
              <div style="font-size:11px; color:#aaa; margin-top:2px;">
                {item.duration}
              </div>
            </div>
            <div class="career-content">
              <div class="position">{item.position}</div>
              <ul>
                {item.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>

    <!-- 학력 -->
    <div class="section">
      <h2>학력</h2>
      {
        education.map((item, i) => (
          <div
            class="edu-item"
            style={i < education.length - 1 ? "margin-bottom: 12px;" : ""}
          >
            <div class="edu-date">{item.period}</div>
            <div class="edu-content">
              <h3>{item.school}</h3>
              <p>{item.major}</p>
            </div>
          </div>
        ))
      }
    </div>

    <span class="page-num">1 / 5</span>
  </div>

  {
    projects.map((proj) => (
      <div class="page">
        <div class="project-header">
          <div class="project-header-top">
            <span class="project-company">{proj.company}</span>
          </div>
          <p class="company-summary">{proj.companySummary}</p>
          <div class="project-meta">
            <div class="meta-item">
              <span class="meta-label">기간</span>
              <span class="meta-value">{proj.period}</span>
            </div>
            <span class="meta-sep">|</span>
            <div class="meta-item">
              <span class="meta-label">역할</span>
              <span class="meta-value">{proj.contribution}</span>
            </div>
          </div>
        </div>

        {proj.sections.map((section, idx) => (
          <div
            class={idx > 0 ? "section-block section-divider" : "section-block"}
          >
            <div class="project-title">{section.title}</div>

            <div class="tech-tags">
              {section.techs?.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>

            <div class="project-section">
              <span class="project-section-label">배경</span>
              <div class="project-content">
                <ul>
                  {section.background.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="project-section">
              <span class="project-section-label">작업 상세</span>
              <div class="project-content">
                <ul>
                  {section.details.map((cat) =>
                    cat.category ? (
                      <li class="category-item">
                        <strong>{cat.category}</strong>
                        <ul class="sub-list">
                          {cat.items.map((sub) => (
                            <li>
                              <span set:html={sub.text} />
                              {sub.subItems && (
                                <ul class="sub-sub-list">
                                  {sub.subItems.map((s) => (
                                    <li set:html={s.text} />
                                  ))}
                                </ul>
                              )}
                            </li>
                          ))}
                        </ul>
                      </li>
                    ) : (
                      cat.items.map((sub) => (
                        <li>
                          <span set:html={sub.text} />
                          {sub.subItems && (
                            <ul class="sub-sub-list">
                              {sub.subItems.map((s) => (
                                <li set:html={s.text} />
                              ))}
                            </ul>
                          )}
                        </li>
                      ))
                    ),
                  )}
                </ul>
              </div>
            </div>

            <div class="project-section">
              <span class="project-section-label">성과</span>
              <div class="project-content">
                <ul>
                  {section.results.map((r) => (
                    <li>{r}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}

        <span class="page-num">{proj.pageNum}</span>
      </div>
    ))
  }

  <button
    id="pdf-btn"
    onclick="window.print()"
    title="PDF로 저장"
    style="
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 50;
    width: 48px;
    height: 48px;
    background: #F97316;
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
  "
    onmouseover="this.style.background='#ea580c'; this.style.transform='scale(1.08)'"
    onmouseout="this.style.background='#F97316'; this.style.transform='scale(1)'"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="7 10 12 15 17 10"></polyline>
      <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
  </button>

  <style is:global>
    @media (max-width: 768px) {
      #pdf-btn {
        display: none !important;
      }
    }
  </style>
</BaseLayout>
