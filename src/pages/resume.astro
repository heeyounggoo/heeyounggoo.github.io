---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="이력서 | 구희영" description="구희영 프론트엔드 개발자 경력기술서">
  <style is:global>
    .page {
      width: 794px;
      min-height: 1123px;
      background: #ffffff;
      margin: 24px auto;
      padding: 60px 64px;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
      position: relative;
    }

    .page h2 {
      font-size: 20px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 16px;
      padding-left: 14px;
      border-left: 4px solid #f97316;
      line-height: 1.3;
    }

    .page h3 {
      font-size: 14px;
      font-weight: 700;
      color: #222222;
      margin-bottom: 6px;
    }

    .page p,
    .page li {
      font-size: 13px;
      line-height: 1.7;
      color: #333333;
    }

    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 40px;
      padding-bottom: 32px;
      border-bottom: 1.5px solid #f0f0f0;
    }

    .header-left h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      color: #111111;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }

    .header-left .tagline {
      font-size: 14px;
      color: #555555;
      margin-bottom: 12px;
      font-weight: 400;
    }

    .header-left .role-badge {
      display: inline-flex;
      align-items: center;
      background: #fff7ed;
      color: #ea580c;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid #fdba74;
    }

    .contact-grid {
      display: flex;
      flex-direction: column;
      gap: 6px;
      text-align: right;
    }

    .contact-item {
      font-size: 12px;
      color: #666666;
      display: flex;
      align-items: center;
      gap: 6px;
      justify-content: flex-end;
    }

    .contact-item .label {
      font-weight: 600;
      color: #f97316;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .section {
      margin-bottom: 36px;
    }

    .career-item {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 16px;
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid #f5f5f5;
    }

    .career-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .career-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
      padding-top: 2px;
      white-space: nowrap;
    }

    .career-date .company {
      font-size: 13px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 2px;
    }

    .career-date .duration {
      font-size: 11px;
      color: #f97316;
      font-weight: 600;
    }

    .career-content .position {
      font-size: 13px;
      font-weight: 600;
      color: #333333;
      margin-bottom: 6px;
    }

    .career-content ul {
      list-style: none;
      padding: 0;
    }

    .career-content ul li {
      padding-left: 14px;
      position: relative;
      margin-bottom: 4px;
      font-size: 12.5px;
      max-width: 65ch;
    }

    .career-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #f97316;
      opacity: 0.7;
    }

    .tech-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .tech-tag {
      font-size: 11.5px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 4px;
      background: #fff7ed;
      color: #ea580c;
      border: 1px solid #fed7aa;
    }

    .tech-tag.secondary {
      background: #f9fafb;
      color: #4b5563;
      border-color: #e5e7eb;
    }

    .project-header {
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 2px solid #f97316;
    }

    .project-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .project-company-badge {
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 3px;
      background: #f97316;
      color: white;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .project-period {
      font-size: 12px;
      color: #888888;
    }

    .project-title {
      font-size: 22px;
      font-weight: 700;
      color: #111111;
      margin-bottom: 6px;
      letter-spacing: -0.3px;
    }

    .project-subtitle {
      font-size: 13px;
      color: #555555;
    }

    .project-section {
      margin-bottom: 24px;
    }

    .project-section-title {
      font-size: 13px;
      font-weight: 700;
      color: #f97316;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 10px;
      padding-bottom: 4px;
      border-bottom: 1px solid #fed7aa;
    }

    .project-content ul {
      list-style: none;
      padding: 0;
    }

    .project-content ul li {
      padding-left: 16px;
      position: relative;
      margin-bottom: 8px;
      font-size: 12.5px;
      max-width: 65ch;
      line-height: 1.7;
    }

    .project-content ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 9px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #f97316;
    }

    .edu-item {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 16px;
      align-items: start;
    }

    .edu-date {
      font-size: 12px;
      color: #888888;
      font-weight: 500;
    }

    .edu-content h3 {
      margin-bottom: 2px;
    }

    .edu-content p {
      font-size: 12px;
      color: #666666;
    }

    .page-num {
      position: absolute;
      bottom: 28px;
      right: 64px;
      font-size: 11px;
      color: #cccccc;
    }

    .page-label {
      position: absolute;
      bottom: 28px;
      left: 64px;
      font-size: 11px;
      color: #cccccc;
    }

    @media print {
      body {
        background: white;
      }
      .page {
        margin: 0;
        box-shadow: none;
        page-break-after: always;
      }
    }
  </style>

  <!-- PAGE A-1: 프로필 요약 -->
  <div class="page">
    <div class="header">
      <div class="header-left">
        <h1>구희영</h1>
        <p class="tagline">함께 일하고 싶은 개발자, 구희영입니다.</p>
        <span class="role-badge">Frontend Developer</span>
      </div>
      <div class="contact-grid">
        <div class="contact-item">
          <span class="label">Email</span>
          <span>gmldud628@gmail.com</span>
        </div>
        <div class="contact-item">
          <span class="label">GitHub</span>
          <span>github.com/heeyounggoo</span>
        </div>
      </div>
    </div>

    <!-- 자기소개 -->
    <div class="section">
      <p
        style="font-size: 13.5px; line-height: 1.9; color: #444444; padding: 16px 20px; background: #fff7ed; border-left: 3px solid #f97316; border-radius: 4px;"
      >
        매 순간 새로운 도전을 두려워하지 않으며, 실행 속에서 배우고 성장하는 것을
        즐깁니다. 이러한 태도로 팀과 함께 더 나은 방향으로 나아가며, 문제를
        해결하는 개발자로서 가치 있는 결과를 만들어가고 싶습니다.
      </p>
    </div>

    <!-- 기술 스택 -->
    <div class="section">
      <h2>기술스택</h2>
      <div style="margin-bottom: 12px;">
        <h3
          style="font-size:12px; color:#888; font-weight:600; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.5px;"
        >
          Frontend
        </h3>
        <div class="tech-tags">
          <span class="tech-tag">React</span>
          <span class="tech-tag">Next.js</span>
          <span class="tech-tag">TypeScript</span>
          <span class="tech-tag">Vue.js</span>
        </div>
      </div>
      <div style="margin-bottom: 12px;">
        <h3
          style="font-size:12px; color:#888; font-weight:600; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.5px;"
        >
          Tools
        </h3>
        <div class="tech-tags">
          <span class="tech-tag secondary">Git</span>
          <span class="tech-tag secondary">Figma</span>
          <span class="tech-tag secondary">Storybook</span>
        </div>
      </div>
    </div>

    <!-- 학력 -->
    <div class="section">
      <h2>학력</h2>
      <div class="edu-item" style="margin-bottom: 16px;">
        <div class="edu-date">2018.03 – 2023.08</div>
        <div class="edu-content">
          <h3>한국방송통신대학교</h3>
          <p>컴퓨터과학과</p>
        </div>
      </div>
      <div class="edu-item">
        <div class="edu-date">2014.03 – 2016.02</div>
        <div class="edu-content">
          <h3>인덕대학교</h3>
          <p>미디어아트앤디자인과</p>
        </div>
      </div>
    </div>

    <!-- 경력 -->
    <div class="section">
      <h2>경력사항</h2>
      <div class="career-item">
        <div class="career-date">
          <div class="company">ANTLabs</div>
          <div class="duration">2019.03 – 2021.07</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">2년</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>대학교 학사 관리 시스템 프론트엔드 개발</li>
            <li>복잡한 폼/워크플로우 UX 개선 및 최적화</li>
            <li>레거시 시스템 현대화 (React + TypeScript 마이그레이션)</li>
          </ul>
        </div>
      </div>

      <div class="career-item">
        <div class="career-date">
          <div class="company">핏투게더</div>
          <div class="duration">2021.08 – 2023.08</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">2년</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>스포츠 선수 리포트 서비스 프론트엔드 개발</li>
            <li>데이터 시각화 기반 리포트 서비스 구현</li>
            <li>ANTLabs 연계 프로젝트 리포트 기능 확장</li>
          </ul>
        </div>
      </div>

      <div class="career-item">
        <div class="career-date">
          <div class="company">라이드</div>
          <div class="duration">2023.10 – 현재</div>
          <div style="font-size:11px; color:#aaa; margin-top:2px;">재직 중</div>
        </div>
        <div class="career-content">
          <div class="position">프론트엔드 개발자</div>
          <ul>
            <li>모빌리티 서비스 프론트엔드 개발 참여</li>
            <li>React 기반 SPA 아키텍처 구현</li>
            <li>사내 디자인시스템 구축 및 컴포넌트 라이브러리 개발</li>
          </ul>
        </div>
      </div>
    </div>

    <span class="page-label">구희영 경력기술서 · Version A</span>
    <span class="page-num">1 / 6</span>
  </div>

  <!-- PAGE A-2: 라이드 모빌리티 서비스 -->
  <div class="page">
    <div class="project-header">
      <div class="project-meta">
        <span class="project-company-badge">라이드</span>
        <span class="project-period">2019.07 – 2021.07</span>
      </div>
      <div class="project-title">모빌리티 서비스 개발</div>
      <div class="project-subtitle">라이드 앱의 사용자 화면 및 예약·결제 플로우 프론트엔드 개발</div>
    </div>

    <div class="project-section">
      <div class="project-section-title">프로젝트 개요</div>
      <div class="project-content">
        <ul>
          <li>React 기반 모빌리티 서비스 사용자 인터페이스 개발</li>
          <li>지도 연동 실시간 차량 위치 추적 기능 구현</li>
          <li>예약, 결제, 탑승 이력 관리 플로우 설계 및 개발</li>
          <li>크로스 플랫폼(웹/모바일 웹) 대응 반응형 UI 개발</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">주요 역할 및 기여</div>
      <div class="project-content">
        <ul>
          <li>신규 예약 플로우 UI/UX 설계 참여 및 컴포넌트 구현</li>
          <li>카카오맵 API 연동 및 커스텀 마커/오버레이 개발</li>
          <li>결제 모듈(PG사 연동) 프론트엔드 통합 작업</li>
          <li>사용자 리뷰 및 별점 시스템 UI 컴포넌트 개발</li>
          <li>성능 최적화: React.memo, useMemo 적용으로 렌더링 30% 개선</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">사용 기술</div>
      <div class="tech-tags">
        <span class="tech-tag">React</span>
        <span class="tech-tag">JavaScript</span>
        <span class="tech-tag">Redux</span>
        <span class="tech-tag secondary">Kakao Map API</span>
        <span class="tech-tag secondary">Styled Components</span>
        <span class="tech-tag secondary">Axios</span>
      </div>
    </div>

    <span class="page-label">구희영 경력기술서 · Version A</span>
    <span class="page-num">2 / 6</span>
  </div>

  <!-- PAGE A-3: 라이드 디자인시스템 -->
  <div class="page">
    <div class="project-header">
      <div class="project-meta">
        <span class="project-company-badge">라이드</span>
        <span class="project-period">2020.01 – 2021.07</span>
      </div>
      <div class="project-title">디자인시스템 구축</div>
      <div class="project-subtitle">서비스 전반에 적용 가능한 재사용 컴포넌트 라이브러리 및 디자인시스템 개발</div>
    </div>

    <div class="project-section">
      <div class="project-section-title">프로젝트 개요</div>
      <div class="project-content">
        <ul>
          <li>디자이너–개발자 협업을 위한 사내 디자인시스템 구축</li>
          <li>40+ 재사용 UI 컴포넌트 라이브러리 설계 및 구현</li>
          <li>Storybook 기반 컴포넌트 문서화 및 시각적 회귀 테스트</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">주요 역할 및 기여</div>
      <div class="project-content">
        <ul>
          <li>Button, Input, Modal, Toast 등 핵심 UI 컴포넌트 설계 및 개발</li>
          <li>디자인 토큰(색상, 타이포그래피, 간격) 체계 수립</li>
          <li>Storybook 문서화로 디자이너·QA 팀 협업 효율 40% 향상</li>
          <li>npm 패키지 배포 파이프라인 구축 (GitHub Actions CI/CD)</li>
          <li>접근성(A11y) 가이드라인 적용 (WCAG 2.1 AA 기준)</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">사용 기술</div>
      <div class="tech-tags">
        <span class="tech-tag">React</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">Storybook</span>
        <span class="tech-tag secondary">Rollup</span>
        <span class="tech-tag secondary">CSS Modules</span>
        <span class="tech-tag secondary">GitHub Actions</span>
      </div>
    </div>

    <span class="page-label">구희영 경력기술서 · Version A</span>
    <span class="page-num">3 / 6</span>
  </div>

  <!-- PAGE A-4: 핏투게더 스포츠 선수 리포트 -->
  <div class="page">
    <div class="project-header">
      <div class="project-meta">
        <span class="project-company-badge" style="background:#EA580C;">핏투게더</span>
        <span class="project-period">2021.08 – 2022.12</span>
      </div>
      <div class="project-title">스포츠 선수 리포트 서비스 개발</div>
      <div class="project-subtitle">전문 스포츠 선수의 퍼포먼스 데이터를 시각화하는 리포트 서비스 프론트엔드 개발</div>
    </div>

    <div class="project-section">
      <div class="project-section-title">프로젝트 개요</div>
      <div class="project-content">
        <ul>
          <li>선수별 퍼포먼스 지표 데이터 시각화 대시보드 개발</li>
          <li>코치·구단 관계자를 위한 분석 리포트 생성 및 공유 시스템</li>
          <li>복잡한 차트/그래프 UI 컴포넌트 개발</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">주요 역할 및 기여</div>
      <div class="project-content">
        <ul>
          <li>Recharts 기반 커스텀 차트 컴포넌트 개발 (레이더, 바, 라인 차트)</li>
          <li>PDF 리포트 생성 기능 구현 (html2canvas + jsPDF)</li>
          <li>선수 비교 분석 UI/UX 설계 및 개발</li>
          <li>데이터 필터링 및 기간별 조회 기능 구현</li>
          <li>반응형 대시보드 레이아웃 설계 (태블릿/데스크톱 최적화)</li>
        </ul>
      </div>
    </div>

    <div class="project-section">
      <div class="project-section-title">사용 기술</div>
      <div class="tech-tags">
        <span class="tech-tag">React</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">Recharts</span>
        <span class="tech-tag secondary">Recoil</span>
        <span class="tech-tag secondary">React Query</span>
        <span class="tech-tag secondary">html2canvas</span>
      </div>
    </div>

    <span class="page-label">구희영 경력기술서 · Version A</span>
    <span class="page-num">4 / 6</span>
  </div>

  <!-- PAGE A-5: 핏투게더 리포트 & ANTLabs -->
  <div class="page">
    <div class="project-header">
      <div class="project-meta">
        <span class="project-company-badge" style="background:#EA580C;">핏투게더 / ANTLabs</span>
        <span class="project-period">2023.01 – 2023.08</span>
