---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { profile } from "../data/profile";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="구희영 | Frontend Developer">
  <!-- Hero -->
  <section class="border-b border-gray-100 pb-16">
    <div class="mb-4">
      <span
        class="inline-flex items-center rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-600"
      >
        Frontend Developer
      </span>
    </div>
    <h1 class="mb-4 text-4xl leading-tight font-bold text-gray-900">
      함께 일하고 싶은 개발자,<br />구희영입니다.
    </h1>
    <p
      class="max-w-2xl text-lg leading-relaxed whitespace-pre-line text-gray-500"
    >
      {profile.bio}
    </p>
    <div class="mt-6 flex gap-4">
      <a
        href="/resume"
        class="inline-flex items-center rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-orange-600"
      >
        이력서 보기
      </a>
      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg border border-gray-200 px-5 py-2.5 text-sm font-semibold text-gray-700 transition-colors hover:border-orange-300 hover:text-orange-500"
      >
        GitHub
      </a>
    </div>
  </section>

  <!-- 기술스택 -->
  <section class="border-b border-gray-100 py-14">
    <h2
      class="mb-6 border-l-4 border-orange-500 pl-3.5 text-xl font-bold text-gray-900"
    >
      기술스택
    </h2>
    <div class="flex flex-col gap-5">
      {
        Object.entries(profile.skills).map(([category, items]) => (
          <div class="flex items-start gap-4">
            <span class="w-28 shrink-0 pt-1 text-xs font-semibold tracking-wide text-gray-400 uppercase">
              {category}
            </span>
            <div class="flex flex-wrap gap-2">
              {items.map((skill) => (
                <span class="rounded border border-orange-100 bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-700">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 최근 포스트 -->
  {
    posts.length > 0 && (
      <section class="pt-14">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="border-l-4 border-orange-500 pl-3.5 text-xl font-bold text-gray-900">
            최근 포스트
          </h2>
          <a
            href="/blog"
            class="text-sm font-medium text-orange-500 transition-colors hover:text-orange-600"
          >
            전체 보기 →
          </a>
        </div>
        <div class="flex flex-col gap-4">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id.replace(/\.mdx$/, "")}`}
              class="group block rounded-lg border border-gray-100 p-5 transition-all hover:border-orange-200 hover:shadow-sm"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="mb-1 font-semibold text-gray-900 transition-colors group-hover:text-orange-500">
                    {post.data.title}
                  </h3>
                  <p class="line-clamp-2 text-sm text-gray-500">
                    {post.data.description}
                  </p>
                </div>
                <time
                  class="shrink-0 pt-0.5 text-xs text-gray-400"
                  datetime={post.data.date.toISOString()}
                >
                  {post.data.date.toLocaleDateString("ko-KR", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
