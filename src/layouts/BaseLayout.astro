---
import "../styles/global.css";
import { profile } from "../data/profile";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "구희영의 포트폴리오 & 기술 블로그" } =
  Astro.props;
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen bg-white text-gray-900"
    style="font-family: 'Pretendard', system-ui, sans-serif;"
  >
    <header
      class="sticky top-0 z-10 border-b border-gray-100 bg-white/95 backdrop-blur-sm"
    >
      <nav
        class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4"
      >
        <a
          href="/"
          class="text-lg font-bold tracking-tight transition-colors hover:text-orange-500"
        >
          heeyounggoo
        </a>
        <ul class="flex items-center gap-6 text-sm font-medium">
          <li>
            <a
              href="/blog"
              class={`hover:text-orange-500 transition-colors ${isActive("/blog") ? "text-orange-500" : "text-gray-600"}`}
            >
              Blog
            </a>
          </li>
          <li>
            <a
              href="/resume"
              class={`hover:text-orange-500 transition-colors ${isActive("/resume") ? "text-orange-500" : "text-gray-600"}`}
            >
              Resume
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="mx-auto max-w-4xl px-6 py-12">
      <slot />
    </main>

    <footer class="mt-16 border-t border-gray-100">
      <div
        class="mx-auto flex max-w-4xl items-center justify-between px-6 py-8 text-sm text-gray-400"
      >
        <span>© {new Date().getFullYear()} 구희영</span>
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-orange-500"
        >
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
