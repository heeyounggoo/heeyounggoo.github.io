---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  description: string;
  categories?: string[];
  tags?: string[];
  image?: { src: string; alt: string };
}

const { title, date, description, categories = [], tags = [], image } = Astro.props;

const formattedDate = date.toLocaleDateString("ko-KR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} | heeyounggoo`} description={description}>
  <article>
    <header class="mb-10">
      {
        categories.length > 0 && (
          <div class="flex gap-2 mb-3">
            {categories.map((cat) => (
              <span class="text-xs font-semibold text-orange-600 bg-orange-50 border border-orange-200 px-3 py-1 rounded-full">
                {cat}
              </span>
            ))}
          </div>
        )
      }
      <h1 class="text-3xl font-bold text-gray-900 leading-tight mb-3">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {
          tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag) => (
                <span class="text-gray-400">#{tag}</span>
              ))}
            </div>
          )
        }
      </div>
      {
        image && (
          <div class="mt-6">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full rounded-lg object-cover shadow-md max-h-72"
            />
          </div>
        )
      }
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>

    <footer class="mt-12 pt-6 border-t border-gray-100">
      <a href="/blog" class="text-sm text-orange-500 hover:text-orange-600 font-medium transition-colors">
        ← 블로그 목록으로
      </a>
    </footer>
  </article>
</BaseLayout>
