{
  "attribution": {
    "commits": false,
    "pullRequests": false
  },
  "permissions": {
    "allow": [
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run preview*)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npx astro *)",
      "Bash(npx prettier *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git stash*)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(curl -sI *)",
      "Bash(curl -s *)",
      "Bash(ls *)",
      "WebSearch",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Read(.env*)"
    ]
  },
  "hooks": {}
}
